// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_POSTGRES_URL_NON_POOLING")
}

/**
 * =========================================================
 * =============== Auth / Users ============================
 * =========================================================
 */
model User {
  id            String    @id @default(cuid())
  name          String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  Cart     Cart[]

  orders  Order[]
  reviews Review[]
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
}

/**
 * =========================================================
 * =============== Password Reset ===========================
 * =========================================================
 */
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

/**
 * =========================================================
 * =============== Store / Products ========================
 * =========================================================
 */

enum TeamType {
  CLUB
  NATION
}

/**
 * 🔹 canal do produto / order
 * GLOBAL = envio normal
 * PT_STOCK_CTT = stock em Portugal enviado pelos CTT
 */
enum ProductChannel {
  GLOBAL
  PT_STOCK_CTT
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  team        String
  teamType    TeamType @default(CLUB)
  season      String?
  basePrice   Int
  description String?

  /**
   * 🔹 canal de venda
   */
  channel ProductChannel @default(GLOBAL)

  /**
   * 🔹 stock local em Portugal
   * null = produto normal/global sem stock PT
   * número = produto PT Stock com quantidade controlada
   */
  ptStockQty Int?

  imageUrls String[] @default([])
  badges    String[] @default([])

  allowNameNumber Boolean @default(true)
  isVisible       Boolean @default(true)

  sizes      SizeStock[]
  options    OptionGroup[] @relation("ProductOptions")
  cartItems  CartItem[]
  orderItems OrderItem[]
  reviews    Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([team])
  @@index([teamType])
  @@index([season])
  @@index([teamType, team])
  @@index([isVisible])
  @@index([channel])
  @@index([ptStockQty])
}

model SizeStock {
  id        String  @id @default(cuid())
  productId String
  size      String
  available Boolean @default(true)

  /**
   * 🔹 stock por tamanho em Portugal
   * este é o campo que deve ser decrementado
   * quando uma order PT Stock é paga
   */
  ptStockQty Int @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size])
  @@index([productId])
  @@index([size])
  @@index([available])
  @@index([ptStockQty])
}

model OptionGroup {
  id        String     @id @default(cuid())
  productId String
  key       String
  label     String
  type      OptionType
  required  Boolean    @default(false)

  product Product       @relation("ProductOptions", fields: [productId], references: [id], onDelete: Cascade)
  values  OptionValue[]

  @@index([productId])
}

model OptionValue {
  id         String @id @default(cuid())
  groupId    String
  value      String
  label      String
  priceDelta Int    @default(0)

  playerId     String?
  playerName   String?
  playerNumber Int?

  group  OptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  player Player?     @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([groupId])
  @@index([playerId])
}

enum OptionType {
  SIZE
  RADIO
  ADDON
}

/**
 * =========================================================
 * =============== Players ================================
 * =========================================================
 */

model Player {
  id        String   @id @default(cuid())
  team      String
  name      String
  number    Int
  position  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  optionValues OptionValue[]

  @@unique([team, name], name: "player_team_name")
  @@index([team])
}

/**
 * =========================================================
 * =============== Cart ====================================
 * =========================================================
 */

model Cart {
  id        String  @id @default(cuid())
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId String? @unique

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  productId String

  qty        Int @default(1)
  unitPrice  Int
  totalPrice Int @default(0)

  optionsJson     Json?
  personalization Json?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
  @@index([productId])
}

/**
 * =========================================================
 * =============== Discount Codes ==========================
 * =========================================================
 */

model DiscountCode {
  id         String  @id @default(cuid())
  code       String  @unique
  percentOff Int     @default(10)
  active     Boolean @default(true)

  /**
   * 🔹 uso único:
   * maxUses e usesCount mantidos para compatibilidade/histórico,
   * mas o fluxo passa a ser de 1 utilização apenas.
   */
  maxUses   Int       @default(1)
  usesCount Int       @default(0)
  usedAt    DateTime?
  expiresAt DateTime?

  /**
   * 🔹 order que consumiu este código
   * um código só pode ficar ligado a UMA única order
   */
  usedByOrderId String? @unique
  usedByOrder   Order?  @relation("DiscountCodeUsedByOrder", fields: [usedByOrderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /**
   * 🔹 integração opcional com Stripe para exibir
   * o desconto como linha separada no Checkout
   * Podes usar um OU outro:
   * - stripeCouponId: cupão do Stripe
   * - stripePromotionCodeId: promotion code do Stripe
   * Normalmente basta stripePromotionCodeId se quiseres
   * espelhar diretamente cada código interno.
   */
  stripeCouponId        String?
  stripePromotionCodeId String?

  @@index([active])
  @@index([code, active])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([usedAt])
  @@index([usedByOrderId])
  @@index([stripeCouponId])
  @@index([stripePromotionCodeId])
}

/**
 * =========================================================
 * =============== Orders ==================================
 * =========================================================
 */

enum OrderStatus {
  pending
  paid
  failed
  canceled
  refunded
  shipped
  delivered
}

enum ShippingStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
}

model Order {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  sessionId String?

  status   String @default("pending")
  currency String @default("eur")

  /**
   * 🔹 canal da order (mesmo enum do Product)
   */
  channel ProductChannel @default(GLOBAL)

  /**
   * 🔹 subtotal dos produtos antes do desconto
   */
  subtotal Int @default(0)

  /**
   * 🔹 subtotal dos produtos antes do desconto
   * campo adicional explícito para o resumo final
   */
  productSubtotalCents Int @default(0)

  /**
   * 🔹 subtotal final dos produtos depois do desconto
   * útil para bater certo com Stripe/resumos/admin
   */
  finalProductSubtotalCents Int @default(0)

  /**
   * 🔹 shipping (em cents) — SINGLE SOURCE OF TRUTH
   */
  shipping Int @default(0)

  /**
   * 🔹 shipping explícito em cents para checkout/resumo
   */
  shippingCents Int @default(0)

  tax Int @default(0)

  total      Float?
  totalCents Int?

  /**
   * 🔹 dados do desconto aplicado à order
   * o vínculo do código consumido fica no model DiscountCode.usedByOrderId
   */
  discountCodeText    String?
  discountPercent     Int?
  discountAmountCents Int     @default(0)

  /**
   * 🔹 ids Stripe ligados ao desconto aplicado
   * guardados na order para auditoria/debug
   */
  stripeCouponIdUsed        String?
  stripePromotionCodeIdUsed String?

  stripeSessionId       String?
  stripePaymentIntentId String?
  paypalOrderId         String?
  paypalCaptured        Boolean?
  paypalCaptureId       String?

  paymentStatus String?
  paidAt        DateTime?

  /**
   * 🔹 usado para impedir descontar stock duas vezes
   * quando o webhook/payment handler repetir
   */
  stockDeductedAt DateTime?

  shippingJson Json?

  shippingFullName   String?
  shippingEmail      String?
  shippingPhone      String?
  shippingAddress1   String?
  shippingAddress2   String?
  shippingCity       String?
  shippingRegion     String?
  shippingPostalCode String?
  shippingCountry    String?

  shippingStatus ShippingStatus @default(PENDING)
  trackingCode   String?
  trackingUrl    String?
  shippedAt      DateTime?
  deliveredAt    DateTime?

  confirmationEmailSentAt     DateTime?
  confirmationEmailProviderId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  /**
   * 🔹 relação inversa do DiscountCode usado por esta order
   * cada order pode ter no máximo um código consumido
   */
  usedDiscountCode DiscountCode? @relation("DiscountCodeUsedByOrder")

  @@index([userId])
  @@index([sessionId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([shippingCountry])
  @@index([paidAt])
  @@index([stockDeductedAt])
  @@index([shippingStatus])
  @@index([shippedAt])
  @@index([deliveredAt])
  @@index([trackingCode])
  @@index([confirmationEmailSentAt])
  @@index([channel])
  @@index([discountCodeText])
  @@index([stripeCouponIdUsed])
  @@index([stripePromotionCodeIdUsed])
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  productId    String
  name         String
  image        String?
  qty          Int
  unitPrice    Int
  totalPrice   Int
  snapshotJson Json?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

/**
 * =========================================================
 * =============== Reviews / Engagement ====================
 * =========================================================
 */

model Review {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  rating    Int
  comment   String?
  imageUrls String[] @default([])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([productId])
  @@index([rating])
  @@index([createdAt])
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model SocialMetric {
  id             String   @id @default(cuid())
  followersTotal Int
  createdAt      DateTime @default(now())

  @@index([createdAt])
}

model Visit {
  id        String   @id @default(cuid())
  visitorId String
  path      String
  referrer  String?
  ua        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([visitorId, createdAt])
}

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  createdAt      DateTime  @default(now())
  unsubToken     String    @unique @default(cuid())
  unsubscribedAt DateTime?
}

model NewsletterCampaign {
  id              String    @id @default(cuid())
  subject         String
  style           String
  contentJson     String
  html            String
  text            String
  status          String    @default("DRAFT")
  totalRecipients Int       @default(0)
  sentCount       Int       @default(0)
  failedCount     Int       @default(0)
  createdAt       DateTime  @default(now())
  sentAt          DateTime?

  logs NewsletterSendLog[]
}

model NewsletterSendLog {
  id         String   @id @default(cuid())
  campaignId String
  email      String
  status     String
  providerId String?
  error      String?
  createdAt  DateTime @default(now())

  campaign NewsletterCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([email])
}
