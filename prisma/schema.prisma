// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_POSTGRES_URL_NON_POOLING")
}

/**
 * =========================================================
 * =============== Auth / Users ============================
 * =========================================================
 */
model User {
  id            String    @id @default(cuid())
  name          String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  Cart     Cart[]

  orders  Order[]
  reviews Review[]
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
}

/**
 * =========================================================
 * =============== Password Reset ===========================
 * =========================================================
 */
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

/**
 * =========================================================
 * =============== Store / Products ========================
 * =========================================================
 */

enum TeamType {
  CLUB
  NATION
}

/**
 * 🔹 canal do produto / order
 * GLOBAL = envio normal
 * PT_STOCK_CTT = stock em Portugal enviado pelos CTT
 */
enum ProductChannel {
  GLOBAL
  PT_STOCK_CTT
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  team        String
  teamType    TeamType @default(CLUB)
  season      String?
  basePrice   Int
  description String?

  /**
   * 🔹 canal de venda
   */
  channel ProductChannel @default(GLOBAL)

  /**
   * 🔹 stock local em Portugal (opcional)
   */
  ptStockQty Int?

  imageUrls String[] @default([])
  badges    String[] @default([])

  allowNameNumber Boolean @default(true)
  isVisible       Boolean @default(true)

  sizes      SizeStock[]
  options    OptionGroup[] @relation("ProductOptions")
  cartItems  CartItem[]
  orderItems OrderItem[]
  reviews    Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([team])
  @@index([teamType])
  @@index([season])
  @@index([teamType, team])
  @@index([isVisible])
  @@index([channel])
}

model SizeStock {
  id        String  @id @default(cuid())
  productId String
  size      String
  available Boolean @default(true)

  product Product @relation(fields: [productId], references: [id])

  @@unique([productId, size])
  @@index([productId])
}

model OptionGroup {
  id        String     @id @default(cuid())
  productId String
  key       String
  label     String
  type      OptionType
  required  Boolean    @default(false)

  product Product      @relation("ProductOptions", fields: [productId], references: [id])
  values  OptionValue[]

  @@index([productId])
}

model OptionValue {
  id         String @id @default(cuid())
  groupId    String
  value      String
  label      String
  priceDelta Int    @default(0)

  playerId     String?
  playerName   String?
  playerNumber Int?

  group  OptionGroup @relation(fields: [groupId], references: [id])
  player Player?     @relation(fields: [playerId], references: [id])

  @@index([groupId])
  @@index([playerId])
}

enum OptionType {
  SIZE
  RADIO
  ADDON
}

/**
 * =========================================================
 * =============== Players ================================
 * =========================================================
 */

model Player {
  id        String   @id @default(cuid())
  team      String
  name      String
  number    Int
  position  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  optionValues OptionValue[]

  @@unique([team, name], name: "player_team_name")
  @@index([team])
}

/**
 * =========================================================
 * =============== Cart ====================================
 * =========================================================
 */

model Cart {
  id        String  @id @default(cuid())
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId String? @unique

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  productId String

  qty        Int @default(1)
  unitPrice  Int
  totalPrice Int @default(0)

  optionsJson     Json?
  personalization Json?

  product Product @relation(fields: [productId], references: [id])
  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
  @@index([productId])
}

/**
 * =========================================================
 * =============== Orders ==================================
 * =========================================================
 */

enum OrderStatus {
  pending
  paid
  failed
  canceled
  refunded
  shipped
  delivered
}

enum ShippingStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
}

model Order {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  sessionId String?

  status   String @default("pending")
  currency String @default("eur")

  /**
   * 🔹 canal da order (mesmo enum do Product)
   */
  channel ProductChannel @default(GLOBAL)

  subtotal Int @default(0)

  /**
   * 🔹 shipping (em cents) — SINGLE SOURCE OF TRUTH
   */
  shipping Int @default(0)

  tax Int @default(0)

  total      Float?
  totalCents Int?

  stripeSessionId       String?
  stripePaymentIntentId String?
  paypalOrderId         String?
  paypalCaptured        Boolean?
  paypalCaptureId       String?

  paymentStatus String?
  paidAt        DateTime?

  shippingJson Json?

  shippingFullName   String?
  shippingEmail      String?
  shippingPhone      String?
  shippingAddress1   String?
  shippingAddress2   String?
  shippingCity       String?
  shippingRegion     String?
  shippingPostalCode String?
  shippingCountry    String?

  shippingStatus ShippingStatus @default(PENDING)
  trackingCode   String?
  trackingUrl    String?
  shippedAt      DateTime?
  deliveredAt    DateTime?

  confirmationEmailSentAt     DateTime?
  confirmationEmailProviderId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([shippingCountry])
  @@index([paidAt])

  @@index([shippingStatus])
  @@index([shippedAt])
  @@index([deliveredAt])
  @@index([trackingCode])

  @@index([confirmationEmailSentAt])

  @@index([channel])
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  productId    String
  name         String
  image        String?
  qty          Int
  unitPrice    Int
  totalPrice   Int
  snapshotJson Json?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

/**
 * =========================================================
 * =============== Reviews / Engagement ====================
 * =========================================================
 */

model Review {
  id String @id @default(cuid())

  userId String?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  rating    Int
  comment   String?
  imageUrls String[] @default([])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([productId])
  @@index([rating])
  @@index([createdAt])
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model SocialMetric {
  id             String   @id @default(cuid())
  followersTotal Int
  createdAt      DateTime @default(now())

  @@index([createdAt])
}

model Visit {
  id        String   @id @default(cuid())
  visitorId String
  path      String
  referrer  String?
  ua        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([visitorId, createdAt])
}

model NewsletterSubscriber {
  id             String   @id @default(cuid())
  email          String   @unique
  createdAt      DateTime @default(now())
  unsubToken     String   @unique @default(cuid())
  unsubscribedAt DateTime?
}

model NewsletterCampaign {
  id              String   @id @default(cuid())
  subject         String
  style           String
  contentJson     String
  html            String
  text            String
  status          String   @default("DRAFT")
  totalRecipients Int      @default(0)
  sentCount       Int      @default(0)
  failedCount     Int      @default(0)
  createdAt       DateTime @default(now())
  sentAt          DateTime?

  logs NewsletterSendLog[]
}

model NewsletterSendLog {
  id         String   @id @default(cuid())
  campaignId String
  email      String
  status     String
  providerId String?
  error      String?
  createdAt  DateTime @default(now())

  campaign NewsletterCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([email])
}